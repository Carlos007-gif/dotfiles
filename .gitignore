# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 🔧 POWERSHELL
# ───────────────────────────────────────────────────────────────

# Ignorar módulos de PowerShell (NO el perfil principal)
*.psd1
*.psm1

# Ignorar historial de consola
ConsoleHost_history.txt

# Ignorar archivos de sesión de PowerShell
*.SessionState

# PERMITIR explícitamente el perfil principal
!Microsoft.PowerShell_profile.ps1
!profile.ps1

# ───────────────────────────────────────────────────────────────
# 🎨 OH MY POSH
# ───────────────────────────────────────────────────────────────

# Ignorar backups de configuraciones (se generan automáticamente)
**/backups/*.omp.json
**/backups/*.omp.yaml
backup-*.omp.json
backup-*.omp.yaml

# Ignorar caché de Oh My Posh
.omp_cache/
cache/

# Ignorar archivos temporales de temas
*.omp.json.tmp
*.omp.yaml.tmp

# PERMITIR configuraciones principales
!*.omp.json
!*.omp.yaml
!oh-my-posh/*.omp.json
!oh-my-posh/*.omp.yaml

# ───────────────────────────────────────────────────────────────
# 👥 USUARIOS (PERSONALIZACIONES)
# ───────────────────────────────────────────────────────────────

# OPCIÓN A: Ignorar todos los temas de usuarios (privacidad)
# users/*/
# users/*/*.omp.json

# OPCIÓN B: Permitir temas de usuarios (compartir configuraciones)
# Descomentar si quieres compartir tus temas personalizados
users/*/*.omp.json

# Ignorar archivos temporales de usuarios
users/*/*.tmp
users/*/*.bak

# ───────────────────────────────────────────────────────────────
# 📦 VERSIONES
# ───────────────────────────────────────────────────────────────

# Permitir todas las versiones del instalador
versions/*/install.ps1
versions/*/CHANGELOG.md

# Ignorar archivos temporales en versiones
versions/*/*.tmp
versions/*/*.log

